# -----------------------------------------------------------------------
# Opterius Mail — environment configuration
# Copy this file to .env and fill in the values for your server.
# -----------------------------------------------------------------------

APP_NAME="Opterius Mail"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mail.example.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# -----------------------------------------------------------------------
# Database
# SQLite (default, zero-config) — change to mysql for production clusters
# -----------------------------------------------------------------------

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=opterius_mail
# DB_USERNAME=root
# DB_PASSWORD=

# -----------------------------------------------------------------------
# Session & cache
# -----------------------------------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database

# -----------------------------------------------------------------------
# IMAP — the mail server users authenticate against
# -----------------------------------------------------------------------

IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_ENCRYPTION=ssl         # ssl | tls | none
IMAP_VALIDATE_CERT=true     # set false for self-signed certs
IMAP_TIMEOUT=15

# Dovecot master user — required for SSO auto-login and the mail:autorespond command.
# Leave blank if not using Dovecot or if those features are not needed.
IMAP_MASTER_USER=
IMAP_MASTER_PASS=

# -----------------------------------------------------------------------
# SMTP — outbound mail relay (same credentials as IMAP)
# -----------------------------------------------------------------------

SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls         # ssl | tls | none
SMTP_VALIDATE_CERT=true

# -----------------------------------------------------------------------
# Admin panel
# MAIL_ADMIN=false  → standalone mode (stats + groups only)
# MAIL_ADMIN=true   → panel-integrated mode (full account/domain management)
# -----------------------------------------------------------------------

MAIL_ADMIN=false

# -----------------------------------------------------------------------
# UI template (leave as 'default' unless you created a custom template)
# -----------------------------------------------------------------------

MAIL_UI_TEMPLATE=default

# -----------------------------------------------------------------------
# Panel SSO — auto-login from Opterius Panel (or any trusted host)
# Set PANEL_SSO_ENABLED=true and choose a strong random secret (32+ chars).
# The panel must be configured with the same PANEL_SSO_SECRET.
# Also requires IMAP_MASTER_USER and IMAP_MASTER_PASS above.
# -----------------------------------------------------------------------

PANEL_SSO_ENABLED=false
PANEL_SSO_SECRET=

# -----------------------------------------------------------------------
# Agent account sync — keeps mail_accounts in sync when accounts are
# created/deleted via the Opterius Panel agent.
# Set to the same value as mail_sync_secret in the agent config.
# Leave blank to disable (standalone mode — mail app manages its own accounts).
# -----------------------------------------------------------------------

MAIL_SYNC_SECRET=
